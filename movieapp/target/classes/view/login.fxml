<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="335" style="-fx-background-color: #0D1117;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.myapp.controller.LoginController">

    <VBox alignment="CENTER" layoutX="68.0" layoutY="172.0" spacing="20" style="-fx-background-color: #00000;" AnchorPane.leftAnchor="68.0" AnchorPane.topAnchor="172.0">

        <Label style="-fx-text-fill: #FF8C00; -fx-border-width: 20;" text="ĐĂNG NHẬP" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <TextField fx:id="txtUsername" promptText="Tên đăng nhập" style="-fx-background-color: transparent;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #B0B0B0;
                          -fx-border-color: white;
                          -fx-border-width: 0 0 1 0;
                          -fx-padding: 8 35 8 8;" />
        <HBox prefHeight="24.0" prefWidth="200.0">
            <children>
                <StackPane>
                    <PasswordField fx:id="pfPassword"
                                   promptText="Mật khẩu"
                                   style="-fx-background-color: transparent;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #B0B0B0;
                          -fx-border-color: white;
                          -fx-border-width: 0 0 1 0;
                          -fx-padding: 8 35 8 8;"/>

                    <TextField fx:id="tfPassword"
                               visible="false"
                               managed="false"
                               style="-fx-background-color: transparent;
                      -fx-text-fill: white;
                      -fx-border-color: white;
                      -fx-border-width: 0 0 1 0;
                      -fx-padding: 8 35 8 8;"/>

                    <ImageView fx:id="iconEye"
                               fitWidth="18"
                               fitHeight="18"
                               pickOnBounds="true"
                               preserveRatio="true"
                               onMouseClicked="#togglePassword"
                               StackPane.alignment="CENTER_RIGHT"
                               style="-fx-opacity: 0.6;">
                        <image>
                            <Image url="@/images/eye.png"/>
                        </image>
                    </ImageView>
                </StackPane>
            </children>
        </HBox>

        <Button fx:id="btnLogin"
                text="Đăng nhập"
                style ="-fx-background-radius: 20"
                onMouseEntered="#hoverLogin"
                onMouseExited="#exitLogin"
                onAction="#handleLogin"/>


        <Label fx:id="lblError"
               text=""
               textFill="#ff5555"
               visible="false"/>


        <Hyperlink onAction="#handleRegister" style="-fx-text-fill: #FF8C00;" text="Chưa có tài khoản? Đăng ký" />

        <Hyperlink onAction="#handleForgotPassword" style="-fx-text-fill: #FF8C00;" text="Quên mật khẩu" />

    </VBox>
    <ImageView fitHeight="96.0" fitWidth="137.0" layoutX="99.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true" />

</AnchorPane>
