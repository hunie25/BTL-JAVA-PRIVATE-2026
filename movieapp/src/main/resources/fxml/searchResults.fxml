<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.myapp.controller.SearchResultsController"
           stylesheets="@../css/app.css"
           styleClass="desktop-background">

    <StackPane fx:id="phoneFrame" maxWidth="390" maxHeight="800" styleClass="mobile-device">
        <VBox spacing="0" style="-fx-background-color: #020617;">

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 40 15 15 15; -fx-background-color: #020617;">
                <Button onAction="#goBack" styleClass="btn-icon-transparent">
                    <graphic>
                        <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="white"/>
                    </graphic>
                </Button>

                <TextField fx:id="txtSearchInner" promptText="Tìm phim khác..."
                           onKeyReleased="#handleSearchKeyReleased"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                                  -fx-background-radius: 15; -fx-padding: 8 12;"/>
            </HBox>

            <VBox style="-fx-padding: 0 20 10 20;">
                <Label fx:id="lblStatus" text="Kết quả cho: ..."
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <content>
                    <FlowPane fx:id="resultContainer" hgap="15" vgap="20"
                              style="-fx-padding: 10 20 100 20;"
                              alignment="TOP_LEFT">
                    </FlowPane>
                </content>
            </ScrollPane>

        </VBox>
    </StackPane>
</StackPane>