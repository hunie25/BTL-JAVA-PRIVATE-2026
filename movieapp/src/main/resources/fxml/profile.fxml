<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.myapp.controller.ProfileController"
           stylesheets="@../css/app.css" styleClass="desktop-background">

    <StackPane maxWidth="390" maxHeight="800" styleClass="mobile-device">
        <VBox style="-fx-background-color: #020617;" spacing="0">

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20;">
                <Button onAction="#goBack" styleClass="btn-icon-transparent">
                    <graphic><SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="white"/></graphic>
                </Button>
                <Label text="Hồ sơ của tôi" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="30" style="-fx-padding: 20;">

                    <VBox alignment="CENTER" spacing="15">
                        <StackPane styleClass="user-avatar-bg" prefWidth="80" prefHeight="80" maxWidth="80">
                            <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                     fill="white" scaleX="2" scaleY="2"/>
                        </StackPane>
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblUsername" text="Tên người dùng" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblEmail" text="email@example.com" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                        </VBox>
                        <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20;"/>
                    </VBox>

                    <VBox spacing="15">
                        <Label text="PHIM ĐÃ XEM" styleClass="section-title"/>
                        <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER" style="-fx-background-color: transparent;">
                            <HBox fx:id="historyContainer" spacing="15" prefHeight="200" style="-fx-padding: 10;">
                                <alignment>CENTER_LEFT</alignment>
                            </HBox>
                        </ScrollPane>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>
</StackPane>