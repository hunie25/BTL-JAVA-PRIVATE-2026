<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.myapp.controller.HomeController"
           stylesheets="@../css/app.css"
           styleClass="desktop-background">

    <StackPane fx:id="phoneFrame" maxWidth="390" maxHeight="800" styleClass="mobile-device">

        <StackPane fx:id="appContent" style="-fx-background-color: #020617;" alignment="TOP_CENTER">

            <ScrollPane fx:id="mainContentScroll" fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" vbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;">

                <VBox spacing="0" style="-fx-background-color: #020617;">

                    <StackPane fx:id="heroContainer" minHeight="650" alignment="TOP_CENTER">
                        <StackPane fx:id="sliderClipPane" style="-fx-background-color: black;">
                            <ImageView fx:id="imgView1" fitWidth="390" preserveRatio="true" StackPane.alignment="TOP_CENTER"/>
                            <ImageView fx:id="imgView2" fitWidth="390" preserveRatio="true" StackPane.alignment="TOP_CENTER"/>
                        </StackPane>

                        <Region style="-fx-background-color: linear-gradient(to top, #020617 15%, rgba(2,6,23,0.8) 50%, transparent 100%);"
                                maxHeight="400" StackPane.alignment="BOTTOM_CENTER"/>

                        <VBox alignment="BOTTOM_CENTER" spacing="10" style="-fx-padding: 0 20 40 20;" StackPane.alignment="BOTTOM_CENTER" pickOnBounds="false">
                            <HBox alignment="BOTTOM_CENTER" spacing="10">
                                <VBox fx:id="heroInfoContainer" spacing="8" HBox.hgrow="ALWAYS" alignment="BOTTOM_LEFT">
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="TOP 1" styleClass="hero-badge-top"/>
                                        <Label text="PHIM NỔI BẬT" style="-fx-text-fill: #22d3ee; -fx-font-weight: 800; -fx-font-size: 10px;"/>
                                    </HBox>
                                    <Label fx:id="heroTitle" text="..." styleClass="hero-title" maxWidth="250"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label fx:id="heroOriginName" text="..." styleClass="hero-meta-text"/>
                                        <Circle radius="2" fill="#ffffff40"/>
                                        <Label fx:id="heroYear" text="2026" styleClass="hero-year-highlight"/>
                                        <Label text="4K ULTRA HD" styleClass="badge-hd"/>
                                    </HBox>
                                </VBox>
                                <VBox alignment="BOTTOM_CENTER" spacing="5">
                                    <Button styleClass="btn-hero-play-side" onAction="#watchHeroMovie">
                                        <graphic>
                                            <SVGPath content="M8 5v14l11-7z" fill="white" scaleX="1.2" scaleY="1.2" style="-fx-translate-x: 2;"/>
                                        </graphic>
                                    </Button>
                                    <Label text="XEM NGAY" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-weight: 900; -fx-font-size: 8px;"/>
                                </VBox>
                            </HBox>
                            <HBox fx:id="heroDots" spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;"/>
                        </VBox>
                    </StackPane>

                    <VBox spacing="22" style="-fx-padding: 0 20 220 20;">

                        <!-- PHIM MỚI (giữ lbSectionTitle + newMoviesContainer để code cũ vẫn chạy) -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region styleClass="section-bar"/>
                                <Label fx:id="lbSectionTitle" text="PHIM MỚI CẬP NHẬT" styleClass="section-title"/>
                            </HBox>

                            <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER"
                                        style="-fx-background-color: transparent;" fitToHeight="true">
                                <HBox fx:id="newMoviesContainer" spacing="15" style="-fx-padding: 5;"/>
                            </ScrollPane>
                        </VBox>

                        <!-- PHIM BỘ HOT -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region styleClass="section-bar"/>
                                <Label text="Phim bộ hot" styleClass="section-title"/>
                            </HBox>

                            <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER"
                                        style="-fx-background-color: transparent;" fitToHeight="true">
                                <HBox fx:id="seriesHotContainer" spacing="15" style="-fx-padding: 5;"/>
                            </ScrollPane>
                        </VBox>

                        <!-- PHIM LẺ MỚI -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region styleClass="section-bar"/>
                                <Label text="Phim lẻ mới" styleClass="section-title"/>
                            </HBox>

                            <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER"
                                        style="-fx-background-color: transparent;" fitToHeight="true">
                                <HBox fx:id="singleNewContainer" spacing="15" style="-fx-padding: 5;"/>
                            </ScrollPane>
                        </VBox>

                        <!-- HOẠT HÌNH ĐẶC SẮC -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region styleClass="section-bar"/>
                                <Label text="Hoạt hình đặc sắc" styleClass="section-title"/>
                            </HBox>

                            <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER"
                                        style="-fx-background-color: transparent;" fitToHeight="true">
                                <HBox fx:id="animeFeaturedContainer" spacing="15" style="-fx-padding: 5;"/>
                            </ScrollPane>
                        </VBox>

                        <!-- FOOTER giống ảnh -->
                        <VBox styleClass="footer-root" spacing="18" style="-fx-padding: 28 0 0 0;">

                            <!-- icon row -->
                            <HBox spacing="18" alignment="CENTER_LEFT">
                                <Button styleClass="footer-icon-btn">
                                    <graphic>
                                        <!-- GitHub icon -->
                                        <SVGPath styleClass="footer-icon"
                                                 content="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.71.5.1.68-.22.68-.48 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.39-3.37-1.39-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.07 1.53 1.07.9 1.57 2.36 1.12 2.93.85.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.1 0-1.13.39-2.06 1.03-2.79-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.06.8-.23 1.65-.35 2.5-.35.85 0 1.7.12 2.5.35 1.9-1.34 2.74-1.06 2.74-1.06.56 1.43.21 2.49.11 2.75.64.73 1.03 1.66 1.03 2.79 0 3.97-2.35 4.84-4.58 5.1.36.32.69.96.69 1.93 0 1.39-.01 2.51-.01 2.85 0 .26.18.58.69.48C19.14 20.6 22 16.78 22 12.26 22 6.58 17.52 2 12 2z"/>
                                    </graphic>
                                </Button>

                                <Button styleClass="footer-icon-btn">
                                    <graphic>
                                        <!-- Twitter-like icon -->
                                        <SVGPath styleClass="footer-icon"
                                                 content="M22 5.9c-.8.4-1.6.6-2.5.8.9-.5 1.5-1.3 1.8-2.3-.8.5-1.8.9-2.8 1.1C15.7 4.7 14.6 4 13.3 4c-2.4 0-4.1 2.3-3.6 4.6-3.3-.2-6.2-1.8-8.2-4.3-1 1.8-.5 4.1 1.2 5.3-.7 0-1.4-.2-2-.6 0 2 1.4 3.8 3.4 4.2-.6.2-1.3.2-2 .1.6 1.8 2.3 3.1 4.3 3.1C4.6 17.8 2.8 18.4 1 18.2c2 1.3 4.4 2.1 6.9 2.1 8.4 0 13.1-7.2 12.8-13.7.9-.6 1.6-1.3 2.2-2.2z"/>
                                    </graphic>
                                </Button>

                                <Button styleClass="footer-icon-btn">
                                    <graphic>
                                        <!-- Mail icon -->
                                        <SVGPath styleClass="footer-icon"
                                                 content="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
                                    </graphic>
                                </Button>
                            </HBox>

                            <!-- link columns -->
                            <HBox spacing="70" alignment="TOP_LEFT">
                                <VBox spacing="14">
                                    <Label text="Mô tả âm thanh" styleClass="footer-link"/>
                                    <Label text="Quan hệ với nhà đầu tư" styleClass="footer-link"/>
                                    <Label text="Thông báo pháp lý" styleClass="footer-link"/>
                                    <Label text="Thẻ quà tặng" styleClass="footer-link"/>
                                    <Label text="Điều khoản sử dụng" styleClass="footer-link"/>
                                    <Label text="Thông tin doanh nghiệp" styleClass="footer-link"/>
                                </VBox>

                                <VBox spacing="14">
                                    <Label text="Trung tâm trợ giúp" styleClass="footer-link"/>
                                    <Label text="Việc làm" styleClass="footer-link"/>
                                    <Label text="Tuỳ chọn cookie" styleClass="footer-link"/>
                                    <Label text="Trung tâm truyền thông" styleClass="footer-link"/>
                                    <Label text="Quyền riêng tư" styleClass="footer-link"/>
                                    <Label text="Liên hệ với chúng tôi" styleClass="footer-link"/>
                                </VBox>
                            </HBox>

                            <Region styleClass="footer-divider"/>

                            <VBox spacing="10" alignment="CENTER">
                                <Label text="© 2026 HUB FILMS. CINEMATIC EXCELLENCE." styleClass="footer-copy"/>
                                <Label text="CRAFTED WITH ♥ BY HUB TEAM" styleClass="footer-tagline"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <VBox alignment="TOP_CENTER" pickOnBounds="false">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-overlay" style="-fx-padding: 10 15;">
                    <VBox spacing="-2" alignment="CENTER_LEFT">
                        <Label text="HUB" styleClass="logo-hub"/>
                        <Label text="FILMS" styleClass="logo-films"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="txtSearch" promptText="Tìm phim..."
                               onKeyReleased="#handleSearchKeyReleased"
                               style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                  -fx-background-radius: 20; -fx-padding: 5 15; -fx-pref-width: 200;"/>

                    <Button fx:id="btnUser" onAction="#handleUserClick" styleClass="btn-icon-transparent">
                        <graphic>
                            <StackPane styleClass="user-avatar-bg">
                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                         fill="white" scaleX="0.9" scaleY="0.9" translateY="1"/>
                            </StackPane>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox alignment="BOTTOM_CENTER" pickOnBounds="false">
                <HBox alignment="CENTER" spacing="40" styleClass="bottom-nav">
                    <Button text="Trang chủ" styleClass="nav-btn, nav-btn-active">
                        <graphic><SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" styleClass="nav-icon-active"/></graphic>
                    </Button>
                    <Button text="Khám phá" styleClass="nav-btn" onAction="#openExplore">
                        <graphic><SVGPath content="M12 10.9c-.61 0-1.1.49-1.1 1.1s.49 1.1 1.1 1.1c.61 0 1.1-.49 1.1-1.1s-.49-1.1-1.1-1.1zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm2.19 12.19L6 18l3.81-8.19L18 6l-3.81 8.19z" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button text="Tải về" styleClass="nav-btn">
                        <graphic><SVGPath content="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button text="Của tôi" styleClass="nav-btn" onAction="#handleUserClick">
                        <graphic><SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="nav-icon"/></graphic>
                    </Button>
                </HBox>
            </VBox>
            <!-- ====================== EXPLORE OVERLAY (THỂ LOẠI) ====================== -->
            <StackPane fx:id="exploreOverlay" visible="false" managed="false" pickOnBounds="true">
                <!-- nền mờ, bấm ra ngoài để đóng -->
                <Region onMouseClicked="#closeExplore"
                        style="-fx-background-color: rgba(0,0,0,0.70);" />

                <!-- panel -->
                <VBox style="-fx-background-color: rgba(0,0,0,0.92);
                 -fx-background-radius: 22;
                 -fx-padding: 22;
                 -fx-pref-width: 340;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 20, 0.25, 0, 4);"
                      StackPane.alignment="CENTER">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="THỂ LOẠI"
                               style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button onAction="#closeExplore"
                                style="-fx-background-color: transparent; -fx-padding: 6; -fx-cursor: hand;">
                            <graphic>
                                <SVGPath fill="rgba(255,255,255,0.60)"
                                         content="M18.3 5.71 12 12l6.3 6.29-1.41 1.42L10.59 13.4 4.3 19.71 2.89 18.29 9.17 12 2.89 5.71 4.3 4.29l6.29 6.3 6.3-6.3z"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- grid 2 cột để đổ danh sách thể loại -->
                    <GridPane fx:id="exploreGrid" hgap="55" vgap="16" style="-fx-padding: 10 0 0 0;"/>
                </VBox>
            </StackPane>
        </StackPane>
    </StackPane>
</StackPane>