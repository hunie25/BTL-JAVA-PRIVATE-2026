<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.myapp.controller.HomeController"
            styleClass="app-root">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              styleClass="topbar"
              BorderPane.alignment="CENTER">
            <Label text="Phim mới cập nhật" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnReload" text="Tải lại" styleClass="btn-dark"/>
        </HBox>
    </top>

    <!-- CENTER: LIST (có padding giống app) -->
    <center>
        <StackPane styleClass="page">
            <ListView fx:id="lvMovies" styleClass="movie-list"/>
        </StackPane>
    </center>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              styleClass="bottombar"
              BorderPane.alignment="CENTER">
            <Label fx:id="lbStatus" text="Đang tải..." styleClass="muted"/>
        </HBox>
    </bottom>

</BorderPane>
