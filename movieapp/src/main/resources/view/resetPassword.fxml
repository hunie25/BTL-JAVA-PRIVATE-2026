<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="350.0" style="-fx-background-color: #0D1117;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.myapp.controller.ResetPasswordController"
            stylesheets="@../css/style.css">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="60.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <ImageView fitHeight="80.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/logo.png" /></image>
                        </ImageView>
                        <Text fill="#00B4D8" styleClass="title-text" text="MẬT KHẨU MỚI">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Text>
                        <Text fill="#8b949e" text="Vui lòng thiết lập mật khẩu mới cho tài khoản của bạn" textAlignment="CENTER" wrappingWidth="260.0" />
                    </children>
                </VBox>

                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Mật khẩu mới" textFill="#8b949e" />
                            <StackPane alignment="CENTER_LEFT">
                                <PasswordField fx:id="pfNewPassword" prefHeight="45.0" styleClass="input-field" />
                                <TextField fx:id="tfNewPassword" managed="false" visible="false" prefHeight="45.0" styleClass="input-field" />
                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.6">
                                    <StackPane.margin><Insets left="12.0" /></StackPane.margin>
                                    <Image url="@../images/lock.png" />
                                </ImageView>
                                <ImageView fitHeight="18.0" fitWidth="18.0" onMouseClicked="#toggleNewPassword" style="-fx-cursor: hand;" StackPane.alignment="CENTER_RIGHT">
                                    <StackPane.margin><Insets right="12.0" /></StackPane.margin>
                                    <Image url="@../images/eye.png" />
                                </ImageView>
                            </StackPane>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Xác nhận mật khẩu" textFill="#8b949e" />
                            <StackPane alignment="CENTER_LEFT">
                                <PasswordField fx:id="pfConfirmPassword" prefHeight="45.0" styleClass="input-field" />
                                <TextField fx:id="tfConfirmPassword" managed="false" visible="false" prefHeight="45.0" styleClass="input-field" />
                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.6">
                                    <StackPane.margin><Insets left="12.0" /></StackPane.margin>
                                    <Image url="@/images/lock.png" />
                                </ImageView>
                            </StackPane>
                        </VBox>
                    </children>
                </VBox>

                <Label fx:id="lblError" styleClass="label-error" visible="false" managed="false" />

                <Button onAction="#handleResetPassword" prefHeight="45.0" prefWidth="300.0" styleClass="btn-primary" text="HOÀN TẤT" />
            </children>
        </VBox>
    </children>
</AnchorPane>