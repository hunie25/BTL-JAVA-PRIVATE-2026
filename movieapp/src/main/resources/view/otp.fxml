<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="335.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.myapp.controller.OtpController"
            stylesheets="@../css/style.css"
            style="-fx-background-color: #0D1117;">

    <children>
        <ImageView fitHeight="104" fitWidth="144" layoutX="95" layoutY="50">
            <image>
                <Image url="@/images/logo.png"/>
            </image>
        </ImageView>

        <Text layoutX="92.0" layoutY="185" fill="DARKORANGE" text="XÁC MINH OTP">
            <font>
                <Font name="System Bold" size="22"/>
            </font>
        </Text>

        <Label fx:id="lblMessage"
               layoutX="20.0" layoutY="205.0"
               prefWidth="295.0" alignment="CENTER"
               wrapText="true"
               text="Vui lòng kiểm tra email và nhập mã OTP"
               style="-fx-text-fill: #8b949e;"/>

        <VBox layoutX="42" layoutY="250" prefWidth="250" spacing="8">
            <children>
                <Label text="Mã xác thực" style="-fx-text-fill: #8b949e;"/>
                <TextField fx:id="txtOtp"
                           prefHeight="40.0"
                           promptText="Nhập 6 chữ số"
                           style="-fx-background-color: #161B22; -fx-text-fill: white; -fx-border-color: #30363D; -fx-border-radius: 5;"/>
            </children>
        </VBox>

        <Label fx:id="lblError"
               layoutX="42" layoutY="310.0"
               prefWidth="250"
               textFill="RED"
               visible="false"
               wrapText="true"
               alignment="CENTER"/>

        <Button fx:id="btnVerify"
                layoutX="58" layoutY="350.0"
                prefWidth="218" prefHeight="40.0"
                text="XÁC NHẬN"
                onAction="#handleVerifyOtp"
                style="-fx-background-radius: 20; -fx-background-color: #ff8c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Hyperlink layoutX="110.0" layoutY="410.0"
                   text="Quay lại đăng nhập"
                   onAction="#goToLogin"
                   style="-fx-text-fill: #8b949e; -fx-underline: false;"/>

    </children>
</AnchorPane>