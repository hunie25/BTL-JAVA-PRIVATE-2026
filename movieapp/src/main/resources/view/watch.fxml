<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.MediaView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.myapp.controller.WatchController"
            prefWidth="420"
            prefHeight="800"
            maxWidth="420"
            maxHeight="800"
            styleClass="app-root">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar">
            <Button fx:id="btnBack" text="← Quay lại" onAction="#onBack" styleClass="btn-accent"/>
            <Label fx:id="lbTitle" text="Đang tải..." styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnNextEp" text="Tập tiếp" onAction="#onNextEpisode" styleClass="btn-dark"/>
        </HBox>
    </top>

    <!-- MAIN (vuốt dọc) -->
    <center>
        <ScrollPane fx:id="spMain"
                    fitToWidth="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="scroll">

            <VBox fx:id="rootContent" spacing="12" styleClass="content">

                <!-- VIDEO + OVERLAY CONTROLS -->
                <StackPane fx:id="videoStack" styleClass="video-stack">

                    <MediaView fx:id="mediaView" preserveRatio="true" styleClass="video-view"/>

                    <!-- overlay tối nhẹ -->
                    <Region fx:id="overlayDim"
                            styleClass="overlay-dim"
                            visible="false" managed="false"
                            mouseTransparent="true"/>

                    <!-- controls overlay (ẩn/hiện khi tap) -->
                    <VBox fx:id="overlayControls"
                          spacing="10"
                          styleClass="overlay-controls"
                          visible="false" managed="false"
                          StackPane.alignment="BOTTOM_CENTER">

                        <HBox spacing="10" alignment="CENTER">
                            <Button fx:id="btnRestart" text="⟲ Từ đầu" onAction="#onRestart" styleClass="btn-dark"/>
                            <Button fx:id="btnPlayPause" text="⏸ Tạm dừng" onAction="#onPlayPause" styleClass="btn-accent"/>
                            <Button fx:id="btnNextEp2" text="⏭ Tập tiếp" onAction="#onNextEpisode" styleClass="btn-dark"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lbTime" text="00:00 / 00:00" styleClass="muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Slider fx:id="slSeek" min="0" max="100" value="0" styleClass="seek"/>
                    </VBox>

                </StackPane>


                <!-- MÔ TẢ -->
                <Label text="Mô tả" styleClass="section-title"/>
                <Label fx:id="lbDesc"
                       text=""
                       wrapText="true"
                       styleClass="desc-label"/>

                <!-- DANH SÁCH TẬP (không ScrollPane con, để spMain cuộn) -->
                <Label text="Danh sách tập" styleClass="section-title"/>
                <FlowPane fx:id="episodePane" hgap="12" vgap="12" styleClass="episodes-pane"/>

                <Region prefHeight="10"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
